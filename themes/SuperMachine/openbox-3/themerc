! SuperMachine Openbox Theme
! Dark transparent-style theme matching Eww/Rofi cyan accent
! Note: Openbox themes cannot do real transparency here; Picom handles transparency.

! Fonts
*.font: shadow=n
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n

! General
border.width: 1
padding.width: 5
padding.height: 4
window.handle.width: 0
window.client.padding.width: 0
menu.overlap: 0
*.justify: center

! Shadows/highlights
*.bg.highlight: 08
*.bg.shadow: 00

! Menu
menu.border.color: #222222
menu.border.width: 0

menu.title.bg: flat solid
menu.title.bg.color: #0F0F0F
menu.title.text.color: #88C0D0

menu.items.bg: flat solid
menu.items.bg.color: #0F0F0F
menu.items.text.color: #F2F2F2
menu.items.disabled.text.color: #555555

menu.items.active.bg: flat solid
menu.items.active.bg.color: #1E2F35
menu.items.active.text.color: #88C0D0

menu.separator.width: 1
menu.separator.padding.width: 6
menu.separator.padding.height: 4
menu.separator.color: #2A2A2A

! Window handles/grips
window.*.handle.bg: flat solid
window.*.handle.bg.color: #111111

window.*.grip.bg: flat solid
window.*.grip.bg.color: #111111

! Window borders
window.*.border.color: #111111
window.active.border.color: #88C0D0
window.inactive.border.color: #202020

! Active window titlebar
window.active.title.separator.color: #88C0D0

window.active.title.bg: flat solid
window.active.title.bg.color: #0F0F0F

window.active.label.bg: parentrelative
window.active.label.text.color: #F2F2F2

window.active.button.*.bg: flat solid
window.active.button.*.bg.color: #0F0F0F
window.active.button.*.image.color: #88C0D0

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #1E2F35
window.active.button.hover.image.color: #FFFFFF

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #88C0D0
window.active.button.pressed.image.color: #0F0F0F

! Inactive window titlebar
window.inactive.title.separator.color: #333333

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #111111

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #777777

window.inactive.button.*.bg: flat solid
window.inactive.button.*.bg.color: #111111
window.inactive.button.*.image.color: #555555

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #1A1A1A
window.inactive.button.hover.image.color: #AAAAAA

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #333333
window.inactive.button.pressed.image.color: #CCCCCC

! OSD
osd.border.width: 1
osd.border.color: #88C0D0

osd.bg: flat solid
osd.bg.color: #111111

osd.active.label.bg: parentrelative
osd.active.label.text.color: #88C0D0

osd.inactive.label.bg: parentrelative
osd.inactive.label.text.color: #777777

osd.hilight.bg: flat solid
osd.hilight.bg.color: #88C0D0

osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #333333