<?xml version="1.0" encoding="UTF-8"?>

<openbox_menu xmlns="http://openbox.org/3.4/menu">

<!-- APPS -->

<menu id="internet-menu" label="Internet">
  <item label="Firefox">
    <action name="Execute">
      <command>firefox</command>
    </action>
  </item>

  <item label="Discord">
    <action name="Execute">
      <command>discord</command>
    </action>
  </item>
</menu>

<menu id="development-menu" label="Development">
  <item label="Visual Studio Code">
    <action name="Execute">
      <command>code</command>
    </action>
  </item>

  <item label="Alacritty">
    <action name="Execute">
      <command>alacritty</command>
    </action>
  </item>
</menu>

<menu id="gaming-menu" label="Gaming">
  <item label="Steam">
    <action name="Execute">
      <command>steam</command>
    </action>
  </item>

  <item label="Moonlight">
    <action name="Execute">
      <command>moonlight</command>
    </action>
  </item>
</menu>

<menu id="media-menu" label="Media">
  <item label="Spotify">
    <action name="Execute">
      <command>spotify</command>
    </action>
  </item>

  <item label="Pavucontrol">
    <action name="Execute">
      <command>pavucontrol</command>
    </action>
  </item>
</menu>

<menu id="files-menu" label="Files">
  <item label="Dolphin">
    <action name="Execute">
      <command>dolphin</command>
    </action>
  </item>

  <item label="File System">
    <action name="Execute">
      <command>dolphin /</command>
    </action>
  </item>
</menu>

<!-- CONFIG EDITS -->

<menu id="conf-menu" label="Conf Edits">

  <item label="Openbox RC">
    <action name="Execute">
      <command>code ~/.config/openbox/rc.xml</command>
    </action>
  </item>

  <item label="Openbox Theme">
  <action name="Execute">
    <command>code ~/.themes/SuperMachine/openbox-3/themerc</command>
  </action>
</item>

  <item label="Openbox Menu">
    <action name="Execute">
      <command>code ~/.config/openbox/menu.xml</command>
    </action>
  </item>

  <item label="Openbox Autostart">
    <action name="Execute">
      <command>code ~/.config/openbox/autostart</command>
    </action>
  </item>

  <separator />

  <item label="Eww Yuck">
    <action name="Execute">
      <command>code ~/.config/eww/eww.yuck</command>
    </action>
  </item>

  <item label="Eww SCSS">
    <action name="Execute">
      <command>code ~/.config/eww/eww.scss</command>
    </action>
  </item>

  <item label="Eww Scripts">
    <action name="Execute">
      <command>code ~/.config/eww/scripts</command>
    </action>
  </item>

  <separator />

  <item label="Picom Config">
    <action name="Execute">
      <command>code ~/.config/picom/picom.conf</command>
    </action>
  </item>

  <item label="Rofi Config">
    <action name="Execute">
      <command>code ~/.config/rofi/config.rasi</command>
    </action>
  </item>

  <item label="Alacritty Config">
    <action name="Execute">
      <command>code ~/.config/alacritty/alacritty.toml</command>
    </action>
  </item>

  <separator />

  <item label="GTK3 Settings">
    <action name="Execute">
      <command>code ~/.config/gtk-3.0/settings.ini</command>
    </action>
  </item>

  <item label="GTK4 Settings">
    <action name="Execute">
      <command>code ~/.config/gtk-4.0/settings.ini</command>
    </action>
  </item>

  <item label="Xresources">
    <action name="Execute">
      <command>code ~/.Xresources</command>
    </action>
  </item>

  <separator />

  <item label="Dotfiles Repo">
    <action name="Execute">
      <command>code ~/dotfiles</command>
    </action>
  </item>

</menu>

<!-- SYSTEM -->

<menu id="system-menu" label="System">
  <item label="Reload Openbox">
    <action name="Reconfigure" />
  </item>

  <item label="Reload Eww">
    <action name="Execute">
      <command>eww reload</command>
    </action>
  </item>

  <item label="Open Sidebar">
    <action name="Execute">
      <command>eww open sidebar</command>
    </action>
  </item>

  <item label="Open Control Center">
    <action name="Execute">
      <command>eww open controlcenter</command>
    </action>
  </item>

  <separator />

  <item label="HTOP">
    <action name="Execute">
      <command>alacritty -e htop</command>
    </action>
  </item>

  <item label="Fastfetch">
    <action name="Execute">
      <command>alacritty -e fastfetch</command>
    </action>
  </item>
</menu>

<!-- POWER -->

<menu id="power-menu" label="Power">
  <item label="Lock">
    <action name="Execute">
      <command>betterlockscreen -l</command>
    </action>
  </item>

  <item label="Reboot">
    <action name="Execute">
      <command>systemctl reboot</command>
    </action>
  </item>

  <item label="Shutdown">
    <action name="Execute">
      <command>systemctl poweroff</command>
    </action>
  </item>

  <item label="Logout">
    <action name="Exit">
      <prompt>yes</prompt>
    </action>
  </item>
</menu>

<!-- ROOT MENU -->

<menu id="root-menu" label="SuperMachine">

  <separator label="Applications"/>

  <menu id="internet-menu"/>
  <menu id="development-menu"/>
  <menu id="gaming-menu"/>
  <menu id="media-menu"/>
  <menu id="files-menu"/>

  <separator label="System"/>

  <menu id="conf-menu"/>
  <menu id="system-menu"/>

  <separator label="Power"/>

  <menu id="power-menu"/>

</menu>

</openbox_menu>