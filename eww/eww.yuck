; Appearance detail panel for Openbox/GTK theme controls.
(defwindow appearancesettings
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "393px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    ; Appearance detail content stays compact at the top of the full-height pane.
    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "fill"
      :vexpand true
      :space-evenly false

    (label :class "settings-title" :halign "start" :text "Appearance")
    (label :class "settings-detail-subtitle" :halign "start" :text { "Openbox: " + THEME_NAME })

    (scroll
      :class "settings-scroll settings-detail-scroll"
      :vscroll true
      :hscroll false
      :valign "fill"
      :vexpand true
      (box
        :orientation "v"
        :spacing 14
        :valign "start"
        :vexpand true
        :space-evenly false

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
        (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/theme-menu.sh" "Switch Openbox Theme")
        (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f lxappearance >/dev/null 2>&1'" "GTK, Icons, Cursor")
        (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f obconf-qt >/dev/null 2>&1'" "Openbox Settings"))

    ; Wallpaper picker updates feh and ~/.fehbg so the choice survives reboot.
    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (label :class "settings-section-title" :halign "start" :text "Wallpaper")
      (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f ~/.config/eww/scripts/wallpaper-picker.sh >/tmp/supermachine-wallpaper-picker.log 2>&1'" "Choose Picture"))

    ; Window layout controls feed the lightweight Openbox smart placement helper.
    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (label :class "settings-section-title" :halign "start" :text "Window Layout")
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/toggle-smart-tiling.sh" { "Semi Tiling: " + SMART_TILING_STATE })
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Smaller window gap" :onclick "~/.config/eww/scripts/set-window-gap.sh down" "−")
        (label :class "settings-step-value" :text { WINDOW_GAP + " px" })
        (button :class "settings-step-button" :tooltip "Larger window gap" :onclick "~/.config/eww/scripts/set-window-gap.sh up" "+"))
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/set-window-border.sh toggle" { "Window Border: " + WINDOW_BORDER_STATE })
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Thinner window border" :onclick "~/.config/eww/scripts/set-window-border.sh thinner" "−")
        (label :class "settings-step-value" :text { WINDOW_BORDER_WIDTH + " px" })
        (button :class "settings-step-button" :tooltip "Thicker window border" :onclick "~/.config/eww/scripts/set-window-border.sh thicker" "+"))
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Less rounded windows" :onclick "~/.config/eww/scripts/set-window-radius.sh down" "−")
        (label :class "settings-step-value" :text { WINDOW_RADIUS + " r" })
        (button :class "settings-step-button" :tooltip "More rounded windows" :onclick "~/.config/eww/scripts/set-window-radius.sh up" "+"))
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/open-color-picker.sh border detail" "Border Color"))

    ; Lightweight panel theme controls stay in Appearance for quick changes.
    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (label :class "settings-section-title" :halign "start" :text "Customize Panel")
      (label :class "settings-preset-name" :halign "start" :text { "Preset: " + GLOW_PRESET })
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/toggle-glow.sh" { "Panel Glow: " + GLOW_STATE })
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Thinner glow" :onclick "~/.config/eww/scripts/set-glow-thickness.sh down" "−")
        (label :class "settings-step-value" :text { GLOW_THICKNESS + " px" })
        (button :class "settings-step-button" :tooltip "Thicker glow" :onclick "~/.config/eww/scripts/set-glow-thickness.sh up" "+"))
      (label :class "settings-section-title" :halign "start" :text "Quick Presets")
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset default" "Default")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset ice" "Ice")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset neon" "Neon"))
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset static-cyan" "Cyan")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset static-orange" "Orange")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset bright-static-lime" "Lime"))
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/toggle-panel-customization.sh" "Advanced Customization"))

    ; Sidebar controls keep the permanent rail adjustable without editing yuck/scss.
    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (label :class "settings-section-title" :halign "start" :text "Side Panel")
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Thinner sidebar" :onclick "~/.config/eww/scripts/set-sidebar-width.sh down" "−")
        (label :class "settings-step-value" :text { SIDEBAR_WIDTH + " px" })
        (button :class "settings-step-button" :tooltip "Wider sidebar" :onclick "~/.config/eww/scripts/set-sidebar-width.sh up" "+"))
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "More transparent" :onclick "~/.config/eww/scripts/set-panel-transparency.sh down" "−")
        (label :class "settings-step-value" :text { PANEL_TRANSPARENCY + "%" })
        (button :class "settings-step-button" :tooltip "Less transparent" :onclick "~/.config/eww/scripts/set-panel-transparency.sh up" "+"))
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Smaller logo" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh size down" "−")
        (label :class "settings-step-value" :text { "Logo " + SIDEBAR_LOGO_SIZE })
        (button :class "settings-step-button" :tooltip "Larger logo" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh size up" "+"))
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Move logo left" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh x down" "←")
        (label :class "settings-step-value" :text { "X " + SIDEBAR_LOGO_X })
        (button :class "settings-step-button" :tooltip "Move logo right" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh x up" "→"))
      (box
        :orientation "h"
        :class "settings-stepper"
        :spacing 8
        :halign "center"
        (button :class "settings-step-button" :tooltip "Move logo up" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh y down" "↑")
        (label :class "settings-step-value" :text { "Y " + SIDEBAR_LOGO_Y })
        (button :class "settings-step-button" :tooltip "Move logo down" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh y up" "↓"))
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/set-sidebar-logo-style.sh reset" "Reset Logo Position")
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/open-sidebar-logo-panel.sh" "Logo Picker")))))))

