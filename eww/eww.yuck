; Keybind detail panel with a small live key capture helper.
(defwindow keybindsettings
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "393px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    ; Keybind detail content stays compact and readable.
    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "start"
      :vexpand false
      :space-evenly false

    (label :class "settings-title" :halign "start" :text "Keybinds")
    (label :class "settings-detail-subtitle" :halign "start" :text "Quick SuperMachine shortcuts")

    (box
      :orientation "v"
      :class {KEY_CAPTURE_STATUS == "Waiting" ? "settings-capture-waiting" : "settings-capture"}
      :spacing 6
      (label :class "settings-section-title" :halign "start" :text {KEY_CAPTURE_STATUS == "Waiting" ? "Waiting for key combo..." : "Key Capture"})
      (label :class "settings-row-subtitle" :halign "start" :text { "Last: " + KEY_CAPTURED_COMBO })
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/capture-keybind.sh" "Listen for Combo"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 8
      (label :class "settings-section-title" :halign "start" :text "Core")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + Tab    System Settings")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + Space  App Launcher")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + T      Terminal")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + E      Files")
      (label :class "settings-row-subtitle" :halign "start" :text "Print          Flameshot"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 8
      (label :class "settings-section-title" :halign "start" :text "Windows")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + Arrows      Tile / maximize")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + 1-4         Switch workspace")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + C           Close window")
      (label :class "settings-row-subtitle" :halign "start" :text "Alt + Tab           Next window")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + L           Lock screen"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f code ~/.config/openbox/rc.xml >/dev/null 2>&1'" "Edit Openbox Keybinds")
      (button :class "settings-wide-action" :onclick "openbox --reconfigure" "Reload Openbox")))))

; System detail panel with metrics and utility launchers.
(defwindow systeminfopanel
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "393px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    ; System detail content stays compact at the top of the full-height pane.
    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "start"
      :vexpand false
      :space-evenly false

    (label :class "settings-title" :halign "start" :text "System")
    (label :class "settings-detail-subtitle" :halign "start" :text { "CPU " + CPU_USAGE + "%    RAM " + RAM_USAGE + "%    GPU " + GPU_USAGE + "%" })

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10

      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰂯")
        (label :class "settings-row-title" :text { "CPU  " + CPU_USAGE + "%  " + CPU_FREQ + " MHz" }))
      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰘚")
        (label :class "settings-row-title" :text { "RAM  " + RAM_USAGE + "%" }))
      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰢮")
        (label :class "settings-row-title" :text { "GPU  " + GPU_USAGE + "%" }))
      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰔏")
        (label :class "settings-row-title" :text { "TEMP " + CPU_TEMP + "°C" }))
        (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f alacritty -e btop >/dev/null 2>&1'" "Open Btop")
        (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f pavucontrol >/dev/null 2>&1'" "Open Audio Mixer"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (label :class "settings-section-title" :halign "start" :text "SuperMachine")
      (label :class "settings-row-subtitle" :halign "start" :text SUPERMACHINE_UPDATE_STATUS)
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/open-welcome.sh" "Open Welcome")
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/update-supermachine.sh check" "Check for Updates")
      (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f ~/.config/eww/scripts/update-supermachine.sh update >/tmp/supermachine-update-launch.log 2>&1'" "Update SuperMachine")))))

; Older compact control center kept available while the new panel evolves.
(defwindow supermachinewelcome
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :width "760px"
    :height "620px"
    :anchor "center")

  (box
    :orientation "v"
    :class "welcome-panel"
    :spacing 16
    :valign "fill"
    :vexpand true

    (box
      :orientation "h"
      :class "settings-header"
      :halign "fill"
      (label :class "welcome-title" :halign "start" :hexpand true :text "SuperMachine V1.0.0")
      (button :class "settings-close" :onclick "~/.config/eww/scripts/close-welcome.sh" "×"))

    (label :class "welcome-copy" :halign "start" :wrap true :text "A modern, minimal Openbox desktop built from Arch, Eww, Rofi, Picom, Alacritty, and curated configs. It is not a from-scratch OS; it is a lightweight desktop package designed to feel fast, personal, and easy to change.")

    (box
      :orientation "h"
      :spacing 14
      :homogeneous true
      (box
        :orientation "v"
        :class "welcome-card"
        :spacing 8
        (label :class "settings-section-title" :halign "start" :text "Core Keys")
        (label :class "settings-row-subtitle" :halign "start" :text "Super + Tab  Settings")
        (label :class "settings-row-subtitle" :halign "start" :text "Super + Space  Apps")
        (label :class "settings-row-subtitle" :halign "start" :text "Super + T  Terminal")
        (label :class "settings-row-subtitle" :halign "start" :text "Print  Screenshot"))
      (box
        :orientation "v"
        :class "welcome-card"
        :spacing 8
        (label :class "settings-section-title" :halign "start" :text "Sidebar")
        (label :class "settings-row-subtitle" :halign "start" :text "Use the left rail for workspaces, time, launcher, and settings.")
        (label :class "settings-row-subtitle" :halign "start" :text "Appearance includes panel themes, radius, wallpaper, and tiling gaps.")))

    (box
      :orientation "h"
      :spacing 14
      :homogeneous true
      (box
        :orientation "v"
        :class "welcome-card"
        :spacing 8
        (label :class "settings-section-title" :halign "start" :text "Performance")
        (label :class "settings-row-subtitle" :halign "start" :text "Perf Mode changes power profile.")
        (label :class "settings-row-subtitle" :halign "start" :text "Fullscreen games auto-hide the sidebar.")
        (label :class "settings-row-subtitle" :halign "start" :text "Semi tiling can be toggled off anytime."))
      (box
        :orientation "v"
        :class "welcome-card"
        :spacing 8
        (label :class "settings-section-title" :halign "start" :text "Updates")
        (label :class "settings-row-subtitle" :halign "start" :text SUPERMACHINE_UPDATE_STATUS)
        (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/update-supermachine.sh check" "Check for Updates")
        (button :class "settings-wide-action" :onclick "bash -lc 'setsid -f ~/.config/eww/scripts/update-supermachine.sh update >/tmp/supermachine-update-launch.log 2>&1'" "Update SuperMachine")))

    (box
      :orientation "h"
      :spacing 12
      :halign "end"
      (button :class "settings-action" :onclick "bash -lc 'setsid -f code ~/dotfiles >/dev/null 2>&1'" "Open Repo")
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/finish-welcome.sh" "Finish Setup"))))

(defwindow controlcenter
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "105px"
    :y "-20px"
    :width "200px"
    :height "340px"
    :anchor "bottom left")

  (box
    :orientation "v"
    :class "controlcenter"
    :spacing -40

    (label
      :class "control-title"
      :text "SuperMachine Control Center")

    (label
      :class "control-sub-title"
      :text "JESUS FIRST")

    (box
      :orientation "h"
      :spacing 6
      :halign "center"
      :valign "center"

      (button
        :class {PERF_STATE == "on" ? "toggle-circle-on" : "toggle-circle-off"}
        :tooltip "Performance Mode"
        :onclick "~/.config/eww/scripts/toggle-performance.sh"
        "󰓅")

      (button
        :class {GAME_STATE == "on" ? "toggle-circle-on" : "toggle-circle-off"}
        :tooltip "Game Mode"
        :onclick "~/.config/eww/scripts/toggle-gamemode.sh"
        "󰊴")

      (button
  :class {NIGHT_STATE == "on" ? "toggle-circle-on" : "toggle-circle-off"}
  :tooltip "Night Mode"
  :onclick "~/.config/eww/scripts/toggle-nightmode.sh"
  "󰖔")
  
      (button :class "toggle-circle-off" :tooltip "Bluetooth" :onclick "" "󰂯"))

    (box
      :orientation "h"
      :spacing 6
      :halign "center"
      :valign "center"

      (button :class "toggle-circle-on"  :tooltip "Wi-Fi" :onclick "" "󰖩")
      (button :class "toggle-circle-off" :tooltip "Focus Mode" :onclick "" "󰝥")
      (button :class "toggle-circle-off" :tooltip "RGB Off" :onclick "" "󰌾")
      (button :class "toggle-circle-off" :tooltip "Stream Mode" :onclick "" "󰐌"))

    (label :class "slider-label" :text "Brightness")

(scale
  :class "quick-slider"
  :min 1
  :max 100
  :value BRIGHTNESS
  :onchange "bash -c 'sudo ddcutil --bus 10 setvcp 10 {}; sudo ddcutil --bus 7 setvcp 10 {}'")

    (label :class "slider-label" :text "Volume")
    (scale
      :class "quick-slider"
      :min 0
      :max 100
      :value VOLUME
      :onchange "pamixer --set-volume {}")

    (box
      :orientation "v"
      :spacing 0

      (label :class "sys-title" :text "System")

      (label
        :class "sys-info"
        :text { "CPU  " + CPU_USAGE + "%   " + CPU_FREQ + " MHz" })

      (label
        :class "sys-info"
        :text { "GPU  " + GPU_USAGE + "%" })

      (label
        :class "sys-info"
        :text { "RAM  " + RAM_USAGE + "%" })

      (label
        :class "sys-info"
        :text { "TEMP " + CPU_TEMP + "°C" }))
  )
)
