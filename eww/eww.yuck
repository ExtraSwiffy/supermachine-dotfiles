; Fourth drawer for picking one of the panel glow and text colors.
(defwindow glowcolorpicker
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "1301px"
    :y "0px"
    :width "300px"
    :height "100%"
