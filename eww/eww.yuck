; Third drawer with full panel theme controls and preset library.
(defwindow panelcustomization
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "823px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "fill"
      :vexpand true
      :space-evenly false

      (label :class "settings-title" :halign "start" :text "Customize Panel")
      (label :class "settings-detail-subtitle" :halign "start" :text { "Preset: " + GLOW_PRESET })

      (scroll
        :class "settings-scroll settings-preset-scroll"
        :vscroll true
        :hscroll false
        :valign "fill"
        :vexpand true
        (box
          :orientation "v"
          :spacing 14
          :valign "start"
          :vexpand true
          :space-evenly false

      ; Full panel customization lives here so Appearance stays compact.
      (box
        :orientation "v"
        :class "settings-section settings-preset-grid"
        :spacing 10
        (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/toggle-glow.sh" { "Panel Glow: " + GLOW_STATE })
        (box
          :orientation "h"
          :spacing 8
          :halign "center"
          (button :class "settings-color-chip settings-color-blue" :tooltip "Pick panel accent color" :onclick "~/.config/eww/scripts/open-color-picker.sh accent advanced" "Accent")
          (button :class "settings-color-chip settings-color-purple" :tooltip "Pick header text color" :onclick "~/.config/eww/scripts/open-color-picker.sh header advanced" "Header")
          (button :class "settings-color-chip settings-color-pink" :tooltip "Pick sub text color" :onclick "~/.config/eww/scripts/open-color-picker.sh subtext advanced" "Sub"))
        (box
          :orientation "h"
          :spacing 8
          :halign "center"
          (button :class "settings-color-chip settings-color-cyan" :tooltip "Pick glow color 1" :onclick "~/.config/eww/scripts/open-color-picker.sh 1 advanced" "1")
          (button :class "settings-color-chip settings-color-blue" :tooltip "Pick glow color 2" :onclick "~/.config/eww/scripts/open-color-picker.sh 2 advanced" "2")
          (button :class "settings-color-chip settings-color-purple" :tooltip "Pick glow color 3" :onclick "~/.config/eww/scripts/open-color-picker.sh 3 advanced" "3")
          (button :class "settings-color-chip settings-color-pink" :tooltip "Pick glow color 4" :onclick "~/.config/eww/scripts/open-color-picker.sh 4 advanced" "4"))
        (box
          :orientation "h"
          :class "settings-stepper"
          :spacing 8
          :halign "center"
          (button :class "settings-step-button" :tooltip "Thinner glow" :onclick "~/.config/eww/scripts/set-glow-thickness.sh down" "−")
          (label :class "settings-step-value" :text { GLOW_THICKNESS + " px" })
          (button :class "settings-step-button" :tooltip "Thicker glow" :onclick "~/.config/eww/scripts/set-glow-thickness.sh up" "+"))
      (label :class "settings-section-title" :halign "start" :text "Animated")
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset default" "Default")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset ice" "Ice")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset neon" "Neon"))
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset sunset" "Sunset")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset matrix" "Matrix")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset vapor" "Vapor"))
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset aurora" "Aurora")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset ember" "Ember")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset ocean" "Ocean"))
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset midnight" "Midnight")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset cyberpunk" "Cyber")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset royal" "Royal"))
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset lagoon" "Lagoon")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset firefly" "Firefly")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset rose-gold" "Rose Gold"))
      (label :class "settings-section-title" :halign "start" :text "Special Themes")
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset berry-crunch" "Berry")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset frosted-milk" "Frosted")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset honey-loop" "Honey"))
      (box
        :orientation "h"
        :spacing 6
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset cocoa-byte" "Cocoa")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset arcade-slush" "Slush")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset galaxy-pop" "Galaxy"))
      (box
        :orientation "h"
