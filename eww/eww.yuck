; Appearance detail panel for Openbox/GTK theme controls.
(defwindow appearancesettings
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "458px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    ; Appearance detail content stays compact at the top of the full-height pane.
    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "start"
      :vexpand false
      :space-evenly false

    (label :class "settings-title" :halign "start" :text "Appearance")
    (label :class "settings-detail-subtitle" :halign "start" :text { "Openbox: " + THEME_NAME })

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
        (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/theme-menu.sh" "Switch Openbox Theme")
        (button :class "settings-wide-action" :onclick "lxappearance" "GTK, Icons, Cursor")
        (button :class "settings-wide-action" :onclick "obconf-qt" "Openbox Settings"))

    ; Glow colors update the SCSS variables and reload Eww.
    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (label :class "settings-section-title" :halign "start" :text "Panel Glow")
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/toggle-glow.sh" { "Panel Glow: " + GLOW_STATE })
      (box
        :orientation "h"
        :spacing 8
        :halign "center"
        (button :class "settings-color-chip settings-color-cyan" :tooltip "Cycle glow color 1" :onclick "~/.config/eww/scripts/set-glow-color.sh 1 cycle" "1")
        (button :class "settings-color-chip settings-color-blue" :tooltip "Cycle glow color 2" :onclick "~/.config/eww/scripts/set-glow-color.sh 2 cycle" "2")
        (button :class "settings-color-chip settings-color-purple" :tooltip "Cycle glow color 3" :onclick "~/.config/eww/scripts/set-glow-color.sh 3 cycle" "3")
        (button :class "settings-color-chip settings-color-pink" :tooltip "Cycle glow color 4" :onclick "~/.config/eww/scripts/set-glow-color.sh 4 cycle" "4"))
      (box
        :orientation "h"
        :spacing 8
        :halign "center"
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset default" "Default")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset ice" "Ice")
        (button :class "settings-action" :onclick "~/.config/eww/scripts/set-glow-color.sh preset neon" "Neon"))))))

; Keybind detail panel with a small live key capture helper.
(defwindow keybindsettings
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "458px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    ; Keybind detail content stays compact and readable.
    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "start"
      :vexpand false
      :space-evenly false

    (label :class "settings-title" :halign "start" :text "Keybinds")
    (label :class "settings-detail-subtitle" :halign "start" :text "Quick SuperMachine shortcuts")

    (box
      :orientation "v"
      :class {KEY_CAPTURE_STATUS == "Waiting" ? "settings-capture-waiting" : "settings-capture"}
      :spacing 6
      (label :class "settings-section-title" :halign "start" :text {KEY_CAPTURE_STATUS == "Waiting" ? "Waiting for key combo..." : "Key Capture"})
      (label :class "settings-row-subtitle" :halign "start" :text { "Last: " + KEY_CAPTURED_COMBO })
      (button :class "settings-wide-action" :onclick "~/.config/eww/scripts/capture-keybind.sh" "Listen for Combo"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 8
      (label :class "settings-section-title" :halign "start" :text "Core")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + Tab    System Settings")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + Space  App Launcher")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + T      Terminal")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + E      Files")
      (label :class "settings-row-subtitle" :halign "start" :text "Print          Flameshot"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 8
      (label :class "settings-section-title" :halign "start" :text "Windows")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + Arrows      Tile / maximize")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + 1-4         Switch workspace")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + C           Close window")
      (label :class "settings-row-subtitle" :halign "start" :text "Alt + Tab           Next window")
      (label :class "settings-row-subtitle" :halign "start" :text "Super + L           Lock screen"))

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10
      (button :class "settings-wide-action" :onclick "code ~/.config/openbox/rc.xml" "Edit Openbox Keybinds")
      (button :class "settings-wide-action" :onclick "openbox --reconfigure" "Reload Openbox")))))

; System detail panel with metrics and utility launchers.
(defwindow systeminfopanel
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "458px"
    :y "0px"
    :width "430px"
    :height "100%"
    :anchor "left center")

  (box
    :orientation "v"
    :class "settings-detail-panel"
    :valign "fill"
    :vexpand true
    :space-evenly false

    ; System detail content stays compact at the top of the full-height pane.
    (box
      :orientation "v"
      :class "settings-content"
      :spacing 14
      :valign "start"
      :vexpand false
      :space-evenly false

    (label :class "settings-title" :halign "start" :text "System")
    (label :class "settings-detail-subtitle" :halign "start" :text { "CPU " + CPU_USAGE + "%    RAM " + RAM_USAGE + "%    GPU " + GPU_USAGE + "%" })

    (box
      :orientation "v"
      :class "settings-section"
      :spacing 10

      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰂯")
        (label :class "settings-row-title" :text { "CPU  " + CPU_USAGE + "%  " + CPU_FREQ + " MHz" }))
      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰘚")
        (label :class "settings-row-title" :text { "RAM  " + RAM_USAGE + "%" }))
      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰢮")
        (label :class "settings-row-title" :text { "GPU  " + GPU_USAGE + "%" }))
      (box
        :orientation "h"
        :class "settings-metric-row"
        :spacing 12
        (label :class "settings-icon" :text "󰔏")
        (label :class "settings-row-title" :text { "TEMP " + CPU_TEMP + "°C" }))
        (button :class "settings-wide-action" :onclick "alacritty -e btop" "Open Btop")
        (button :class "settings-wide-action" :onclick "pavucontrol" "Open Audio Mixer")))))

; Older compact control center kept available while the new panel evolves.
(defwindow controlcenter
  :monitor 0
  :stacking "fg"
  :focusable true

  :geometry (geometry
    :x "105px"
    :y "-20px"
    :width "200px"
    :height "340px"
    :anchor "bottom left")

  (box
    :orientation "v"
    :class "controlcenter"
    :spacing -40

    (label
      :class "control-title"
      :text "SuperMachine Control Center")

    (label
      :class "control-sub-title"
      :text "JESUS FIRST")

    (box
      :orientation "h"
      :spacing 6
      :halign "center"
      :valign "center"

      (button
        :class {PERF_STATE == "on" ? "toggle-circle-on" : "toggle-circle-off"}
        :tooltip "Performance Mode"
        :onclick "~/.config/eww/scripts/toggle-performance.sh"
        "󰓅")

      (button
        :class {GAME_STATE == "on" ? "toggle-circle-on" : "toggle-circle-off"}
        :tooltip "Game Mode"
        :onclick "~/.config/eww/scripts/toggle-gamemode.sh"
        "󰊴")

      (button
  :class {NIGHT_STATE == "on" ? "toggle-circle-on" : "toggle-circle-off"}
  :tooltip "Night Mode"
  :onclick "~/.config/eww/scripts/toggle-nightmode.sh"
  "󰖔")
  
      (button :class "toggle-circle-off" :tooltip "Bluetooth" :onclick "" "󰂯"))

    (box
      :orientation "h"
      :spacing 6
      :halign "center"
      :valign "center"

      (button :class "toggle-circle-on"  :tooltip "Wi-Fi" :onclick "" "󰖩")
      (button :class "toggle-circle-off" :tooltip "Focus Mode" :onclick "" "󰝥")
      (button :class "toggle-circle-off" :tooltip "RGB Off" :onclick "" "󰌾")
      (button :class "toggle-circle-off" :tooltip "Stream Mode" :onclick "" "󰐌"))

    (label :class "slider-label" :text "Brightness")

(scale
  :class "quick-slider"
  :min 1
  :max 100
  :value BRIGHTNESS
  :onchange "bash -c 'sudo ddcutil --bus 10 setvcp 10 {}; sudo ddcutil --bus 7 setvcp 10 {}'")

    (label :class "slider-label" :text "Volume")
    (scale
      :class "quick-slider"
      :min 0
      :max 100
      :value VOLUME
      :onchange "pamixer --set-volume {}")

    (box
      :orientation "v"
      :spacing 0

      (label :class "sys-title" :text "System")

      (label
        :class "sys-info"
        :text { "CPU  " + CPU_USAGE + "%   " + CPU_FREQ + " MHz" })

      (label
        :class "sys-info"
        :text { "GPU  " + GPU_USAGE + "%" })

      (label
        :class "sys-info"
        :text { "RAM  " + RAM_USAGE + "%" })

      (label
        :class "sys-info"
        :text { "TEMP " + CPU_TEMP + "°C" }))
  )
)
